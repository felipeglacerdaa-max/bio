# Configuração Nginx com Headers de Segurança

## Arquivo: /etc/nginx/sites-available/seu-dominio

```nginx
# ============================================================================
# REDIRECIONAMENTO HTTP → HTTPS
# ============================================================================
server {
    listen 80;
    listen [::]:80;
    server_name seu-dominio.com www.seu-dominio.com;
    
    # Força HTTPS
    return 301 https://$server_name$request_uri;
}

# ============================================================================
# CONFIGURAÇÃO HTTPS
# ============================================================================
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    
    server_name seu-dominio.com www.seu-dominio.com;
    
    # Diretório da aplicação
    root /var/www/seu-dominio;
    index index.html index.htm;
    
    # ====================================================================
    # CERTIFICADO SSL/TLS
    # ====================================================================
    ssl_certificate /etc/letsencrypt/live/seu-dominio.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/seu-dominio.com/privkey.pem;
    
    # Protocolos modernos (TLS 1.2+)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    
    # ====================================================================
    # HEADERS DE SEGURANÇA
    # ====================================================================
    
    # HSTS - Force HTTPS for 1 year
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    
    # Previne clickjacking
    add_header X-Frame-Options "DENY" always;
    
    # Desativa mimetype sniffing
    add_header X-Content-Type-Options "nosniff" always;
    
    # XSS Protection
    add_header X-XSS-Protection "1; mode=block" always;
    
    # Content Security Policy
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://wa.me https://www.instagram.com https://www.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
    
    # Referrer Policy
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    
    # Permissions Policy
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()" always;
    
    # Remove headers de informação
    proxy_hide_header X-Powered-By;
    proxy_hide_header Server;
    
    # ====================================================================
    # CACHE
    # ====================================================================
    
    # Cache control
    location ~* \.(html)$ {
        add_header Cache-Control "public, max-age=3600";
    }
    
    location ~* \.(css|js)$ {
        add_header Cache-Control "public, max-age=2592000";
        expires 30d;
    }
    
    location ~* \.(png|jpg|jpeg|gif|ico|svg|webp|woff|woff2)$ {
        add_header Cache-Control "public, max-age=2592000";
        expires 30d;
    }
    
    # ====================================================================
    # COMPRESSÃO
    # ====================================================================
    
    gzip on;
    gzip_vary on;
    gzip_min_length 1000;
    gzip_proxied any;
    gzip_types text/plain text/css text/xml text/javascript 
               application/x-javascript application/xml+rss 
               application/javascript application/json;
    gzip_disable "MSIE [1-6]\.";
    
    # ====================================================================
    # SEGURANÇA
    # ====================================================================
    
    # Bloqueia acesso a arquivos sensíveis
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
    
    # Bloqueia acesso a extensões sensíveis
    location ~ \.(env|config|md|sql|json)$ {
        deny all;
        access_log off;
        log_not_found off;
    }
    
    # Desativa directory listing
    autoindex off;
    
    # ====================================================================
    # LOGGING
    # ====================================================================
    
    access_log /var/log/nginx/seu-dominio-access.log;
    error_log /var/log/nginx/seu-dominio-error.log;
    
    # ====================================================================
    # ROTEAMENTO
    # ====================================================================
    
    # Página inicial
    location / {
        try_files $uri $uri/ =404;
    }
    
    # Redireciona para index.html se arquivo não encontrado
    error_page 404 /index.html;
    
    # Bloqueia acesso a certas extensões
    location ~ \.php$ {
        deny all;
    }
    
    location ~ \.asp$ {
        deny all;
    }
}

# ============================================================================
# UPLOAD DE CERTIFICADO AUTO-RENOVÁVEL
# ============================================================================

# Se usar certbot com Nginx:
# sudo apt-get install python3-certbot-nginx
# sudo certbot --nginx -d seu-dominio.com
# 
# Certbot vai configurar automaticamente e adicionar renew hook

# ============================================================================
# TESTE
# ============================================================================

# Validar configuração
# sudo nginx -t

# Recarregar Nginx
# sudo systemctl reload nginx

# Verificar SSL
# curl -I https://seu-dominio.com
# openssl s_client -connect seu-dominio.com:443
```

---

## Passos para Implementar

### 1. Criar arquivo de configuração

```bash
sudo nano /etc/nginx/sites-available/seu-dominio
# Cole o conteúdo acima e edite os dados
```

### 2. Ativar site

```bash
sudo ln -s /etc/nginx/sites-available/seu-dominio /etc/nginx/sites-enabled/
```

### 3. Testar configuração

```bash
sudo nginx -t
```

### 4. Obter certificado SSL

```bash
sudo apt-get update
sudo apt-get install certbot python3-certbot-nginx
sudo certbot --nginx -d seu-dominio.com -d www.seu-dominio.com
```

### 5. Recarregar Nginx

```bash
sudo systemctl reload nginx
```

### 6. Verificar

```bash
curl -I https://seu-dominio.com
```

---

## Renovação Automática (Let's Encrypt)

```bash
# Verificar renovação
sudo certbot renew --dry-run

# Configurar auto-renew (cron job)
sudo systemctl enable certbot.timer
sudo systemctl start certbot.timer
```

---

## Troubleshooting

### Erro: Too many redirects
- Verificar se está forçando HTTPS corretamente
- Testar em navegador incógnito
- Limpar cache do navegador

### Erro 502 Bad Gateway
```bash
sudo systemctl status nginx
sudo nginx -t
sudo systemctl restart nginx
```

### Certificado não reconhecido
```bash
# Forçar renovação
sudo certbot renew --force-renewal

# Ou certificado está vencendo
sudo certbot certificates
```

---

## Monitor de Performance

```bash
# Ver requisições em tempo real
sudo tail -f /var/log/nginx/seu-dominio-access.log

# Ver erros
sudo tail -f /var/log/nginx/seu-dominio-error.log

# Estatísticas de conexão
netstat -tlnp | grep nginx
```

---

## Configuração de Firewall (UFW)

```bash
# Abrir portas
sudo ufw allow 80/tcp
sudo ufw allow 443/tcp
sudo ufw allow 22/tcp   # SSH

# Ativar firewall
sudo ufw enable

# Verificar
sudo ufw status
```

